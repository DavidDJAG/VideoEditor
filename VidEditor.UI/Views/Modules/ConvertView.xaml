<UserControl x:Class="VidEditor.UI.Views.Modules.ConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="860">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Width="420">
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Convert Pro" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="El modelo ConvertOptions ya está expuesto en la UI. Esta vista genera el comando FFmpeg en vivo, valida compatibilidad y ajusta listas de codecs según la instalación detectada." />
                </StackPanel>

                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <CheckBox Margin="0,2,12,0"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ConvertShowAdvancedOptions}"
                              Content="Advanced mode" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding RefreshConvertCapabilitiesCommand}"
                            Content="Reload capabilities" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding ApplyBalancedConvertPresetCommand}"
                            Content="Balanced H.264" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding ApplyEfficientH265ConvertPresetCommand}"
                            Content="Efficient H.265" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding ApplyReferenceAv1ConvertPresetCommand}"
                            Content="AV1 10-bit MKV" />
                    <Button Command="{Binding ApplyStreamCopyConvertPresetCommand}"
                            Content="Stream Copy" />
                </WrapPanel>
            </DockPanel>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Preset library" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="Save and reload your own Convert presets. Built-in presets stay read-only, while user presets are stored in the local app settings." />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Available presets" />
                            <ComboBox Margin="0,4,0,0"
                                      ItemsSource="{Binding ConvertPresetLibraryNames}"
                                      SelectedItem="{Binding ConvertSelectedPresetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Margin="0,0,8,0"
                                        MinWidth="88"
                                        Command="{Binding LoadSelectedConvertPresetCommand}"
                                        Content="Load" />
                                <Button Margin="0,0,8,0"
                                        MinWidth="88"
                                        Command="{Binding DeleteSelectedConvertPresetCommand}"
                                        Content="Delete" />
                                <Button Margin="0,0,8,0"
                                        MinWidth="98"
                                        Command="{Binding ExportSelectedConvertPresetCommand}"
                                        Content="Export JSON" />
                                <Button MinWidth="98"
                                        Command="{Binding ImportConvertPresetsCommand}"
                                        Content="Import JSON" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Preset name" />
                            <TextBox Margin="0,4,0,0"
                                     Text="{Binding ConvertPresetDraftName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,8,0,0"
                                    Command="{Binding SaveCurrentConvertPresetCommand}"
                                    Content="Save current as preset" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertPresetLibraryStatus, Mode=OneWay}" />

                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Adaptive preset guidance" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertAdaptivePresetSummary, Mode=OneWay}" />

                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Optimization hints for the current setup" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertOptimizationSummary, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="FFmpeg capabilities" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertCapabilitiesStatus}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertHardwareAccelerationSummary}" />
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Input" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding ConvertInputPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2"
                                        MinWidth="92"
                                        Command="{Binding OpenConvertInputCommand}"
                                        Content="Open" />
                                <Button Grid.Column="4"
                                        MinWidth="92"
                                        Command="{Binding RefreshConvertInputProbeCommand}"
                                        Content="Analyze" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Output" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding ConvertOutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2"
                                        MinWidth="92"
                                        Command="{Binding SaveConvertOutputCommand}"
                                        Content="Save As" />
                                <Button Grid.Column="4"
                                        MinWidth="88"
                                        Command="{Binding SyncConvertOutputExtensionCommand}"
                                        Content="Sync Ext" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,14,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Output naming and batch" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SecondaryTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Text="Use a name template for single outputs and queue-ready batch jobs. Supported tokens: {name}, {preset}, {container}, {vcodec}, {acodec}, {height}, {fps}, {tag}." />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Naming template" />
                            <TextBox Margin="0,4,0,0"
                                     Text="{Binding ConvertOutputNamingTemplate, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Generated output preview" />
                            <TextBox Margin="0,4,0,0"
                                     IsReadOnly="True"
                                     Text="{Binding ConvertOutputNamePreview, Mode=OneWay}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Margin="0,0,8,0"
                                        Command="{Binding ApplyConvertSuggestedNameCommand}"
                                        Content="Apply Suggested Name" />
                                <Button Margin="0,0,8,0"
                                        Command="{Binding AddConvertBatchInputsCommand}"
                                        Content="Add Batch Inputs" />
                                <Button Margin="0,0,8,0"
                                        Command="{Binding ClearConvertBatchInputsCommand}"
                                        Content="Clear Batch" />
                                <Button Margin="0,0,8,0"
                                        Command="{Binding CreateConvertBatchDraftsCommand}"
                                        Content="Create Batch Drafts" />
                                <Button Command="{Binding AddConvertBatchToQueueCommand}"
                                        Content="Add Batch to Queue" />
                            </WrapPanel>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SecondaryTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ConvertBatchSummary, Mode=OneWay}" />
                            <ItemsControl Margin="0,8,0,0"
                                          Visibility="{Binding ConvertHasBatchInputs, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          ItemsSource="{Binding ConvertBatchInputPaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource SecondaryTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Input analysis (ffprobe)" />

                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConvertInputProbeStatus, Mode=OneWay}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConvertInputSourceSummary, Mode=OneWay}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConvertInputStreamsSummary, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Detected streams" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConvertInputVideoSummary, Mode=OneWay}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConvertInputAudioSummary, Mode=OneWay}" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource LabelTextBlockStyle}"
                                   Text="Recommendations" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConvertInputRecommendationSummary, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Source stream mapping" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="Lock Convert to the exact source streams detected by ffprobe instead of relying on FFmpeg default stream selection." />

                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Video source stream" />
                        <ComboBox Margin="0,4,0,0"
                                  ItemsSource="{Binding ConvertVideoStreamOptions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding ConvertVideoSourceStreamIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Audio source stream" />
                        <ComboBox Margin="0,4,0,0"
                                  ItemsSource="{Binding ConvertAudioStreamOptions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding ConvertAudioSourceStreamIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Additional audio streams" />
                        <TextBox Margin="0,4,0,0"
                                 Text="{Binding ConvertAudioAdditionalStreamIndexesText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="Comma-separated additional audio stream indexes (for example: 1,2). These are mapped in addition to the primary audio stream." />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Subtitles and metadata" />

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Subtitle handling" />
                        <ComboBox Margin="0,4,0,0"
                                  ItemsSource="{Binding ConvertSubtitleProcessingModes}"
                                  SelectedItem="{Binding ConvertSubtitleMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Subtitle source stream" />
                        <ComboBox Margin="0,4,0,0"
                                  IsEnabled="{Binding ConvertSubtitleCanSelectStream}"
                                  ItemsSource="{Binding ConvertSubtitleStreamOptions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding ConvertSubtitleSourceStreamIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Additional subtitle streams" />
                        <TextBox Margin="0,4,0,0"
                                 IsEnabled="{Binding ConvertSubtitleCanSelectStream}"
                                 Text="{Binding ConvertSubtitleAdditionalStreamIndexesText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="Comma-separated additional subtitle stream indexes for copy or subtitle re-encode workflows. Burn-in supports only one primary subtitle stream." />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Subtitle codec" />
                        <ComboBox Margin="0,4,0,0"
                                  IsEnabled="{Binding ConvertSubtitleCanConfigureCodec}"
                                  ItemsSource="{Binding ConvertSubtitleCodecOptions}"
                                  SelectedItem="{Binding ConvertSubtitleCodec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Subtitle language tag" />
                                <TextBox Margin="0,4,0,0"
                                         IsEnabled="{Binding ConvertSubtitleCanSelectStream}"
                                         Text="{Binding ConvertSubtitleLanguage, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <CheckBox Grid.Column="2"
                                      Margin="0,24,0,0"
                                      IsChecked="{Binding ConvertSubtitleSetAsDefault}"
                                      IsEnabled="{Binding ConvertSubtitleCanSelectStream}"
                                      Content="Default subtitle" />
                        </Grid>

                        <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Metadata and chapters" />
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox Margin="0,0,12,0"
                                      IsChecked="{Binding ConvertMetadataCopySourceMetadata}"
                                      Content="Copy metadata" />
                            <CheckBox IsChecked="{Binding ConvertMetadataCopyChapters}"
                                      Content="Copy chapters" />
                        </WrapPanel>

                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Title override" />
                        <TextBox Margin="0,4,0,0"
                                 Text="{Binding ConvertMetadataTitle, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Artist/author override" />
                        <TextBox Margin="0,4,0,0"
                                 Text="{Binding ConvertMetadataArtist, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Comment override" />
                        <TextBox Margin="0,4,0,0"
                                 Text="{Binding ConvertMetadataComment, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Video" />
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Mode" />
                        <ComboBox Margin="0,4,0,0"
                                  ItemsSource="{Binding ConvertStreamProcessingModes}"
                                  SelectedItem="{Binding ConvertVideoMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Codec" />
                        <ComboBox Margin="0,4,0,0"
                                  IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                  ItemsSource="{Binding ConvertVideoCodecOptions}"
                                  SelectedItem="{Binding ConvertVideoCodec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Rate control" />
                        <ComboBox Margin="0,4,0,0"
                                  IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                  ItemsSource="{Binding ConvertVideoRateControlModes}"
                                  SelectedItem="{Binding ConvertVideoRateControlMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding ConvertVideoShowCrf, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="CRF" />
                            <TextBox Margin="0,4,0,0"
                                     Text="{Binding ConvertVideoCrfText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding ConvertVideoShowBitrate, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Video bitrate" />
                            <TextBox Margin="0,4,0,0"
                                     Text="{Binding ConvertVideoBitrate, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding ConvertVideoShowTwoPass, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Pass mode" />
                            <ComboBox Margin="0,4,0,0"
                                      IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                      ItemsSource="{Binding ConvertVideoPassModes}"
                                      SelectedItem="{Binding ConvertVideoPassMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="FPS" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                      ItemsSource="{Binding ConvertFrameRateModes}"
                                      SelectedItem="{Binding ConvertVideoFrameRateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="2"
                                     IsEnabled="{Binding ConvertVideoShowFrameRate}"
                                     Text="{Binding ConvertVideoFrameRateText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Scale" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                      ItemsSource="{Binding ConvertScaleModes}"
                                      SelectedItem="{Binding ConvertVideoScaleMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="2"
                                     IsEnabled="{Binding ConvertVideoShowScale}"
                                     Text="{Binding ConvertVideoWidthText, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="4"
                                     IsEnabled="{Binding ConvertVideoShowScale}"
                                     Text="{Binding ConvertVideoHeightText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding ConvertShowAdvancedOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Advanced video" />

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Preset" />
                                    <ComboBox Margin="0,4,0,0"
                                              IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                              ItemsSource="{Binding ConvertVideoPresetOptions}"
                                              SelectedItem="{Binding ConvertVideoPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Tune" />
                                    <ComboBox Margin="0,4,0,0"
                                              IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                              ItemsSource="{Binding ConvertVideoTuneOptions}"
                                              SelectedItem="{Binding ConvertVideoTune, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Pixel format" />
                                    <ComboBox Margin="0,4,0,0"
                                              IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                              ItemsSource="{Binding ConvertVideoPixelFormatOptions}"
                                              SelectedItem="{Binding ConvertVideoPixelFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="GOP" />
                                    <TextBox Margin="0,4,0,0"
                                             IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                             Text="{Binding ConvertVideoGopText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Profile" />
                                    <ComboBox Margin="0,4,0,0"
                                              IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                              ItemsSource="{Binding ConvertVideoProfileOptions}"
                                              SelectedItem="{Binding ConvertVideoProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Level" />
                                    <ComboBox Margin="0,4,0,0"
                                              IsEnabled="{Binding ConvertVideoIsEncodingEnabled}"
                                              ItemsSource="{Binding ConvertVideoLevelOptions}"
                                              SelectedItem="{Binding ConvertVideoLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Deinterlace" />
                            <ComboBox Margin="0,4,0,0"
                                      IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                      ItemsSource="{Binding ConvertVideoDeinterlaceModes}"
                                      SelectedItem="{Binding ConvertVideoDeinterlaceMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Crop (X / Y / Width / Height)" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoCropXText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="2"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoCropYText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="4"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoCropWidthText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="6"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoCropHeightText, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Margin="0,12,0,0"
                                      IsChecked="{Binding ConvertVideoPadEnabled}"
                                      IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                      Content="Pad to canvas after crop/scale" />

                            <Grid Margin="0,8,0,0"
                                  Visibility="{Binding ConvertVideoShowPadOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoPadWidthText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="2"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoPadHeightText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="4"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoPadXText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="6"
                                         IsEnabled="{Binding ConvertVideoCanUseFilterControls}"
                                         Text="{Binding ConvertVideoPadYText, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Audio" />
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Mode" />
                        <ComboBox Margin="0,4,0,0"
                                  ItemsSource="{Binding ConvertStreamProcessingModes}"
                                  SelectedItem="{Binding ConvertAudioMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Codec" />
                        <ComboBox Margin="0,4,0,0"
                                  IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                  ItemsSource="{Binding ConvertAudioCodecOptions}"
                                  SelectedItem="{Binding ConvertAudioCodec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Audio bitrate" />
                        <TextBox Margin="0,4,0,0"
                                 IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                 Text="{Binding ConvertAudioBitrate, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Sample rate" />
                                <TextBox Margin="0,4,0,0"
                                         IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                         Text="{Binding ConvertAudioSampleRateText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Channels" />
                                <TextBox Margin="0,4,0,0"
                                         IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                         Text="{Binding ConvertAudioChannelsText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding ConvertShowAdvancedOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Advanced audio / output" />

                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Channel layout" />
                            <ComboBox Margin="0,4,0,0"
                                      IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                      ItemsSource="{Binding ConvertAudioChannelLayoutOptions}"
                                      SelectedItem="{Binding ConvertAudioChannelLayout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Normalization" />
                            <ComboBox Margin="0,4,0,0"
                                      IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                      ItemsSource="{Binding ConvertAudioNormalizationModes}"
                                      SelectedItem="{Binding ConvertAudioNormalizationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,8,0,0"
                                  Visibility="{Binding ConvertAudioShowNormalizationControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Target LUFS" />
                                    <TextBox Margin="0,4,0,0"
                                             IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                             Text="{Binding ConvertAudioLoudnessTargetText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="True peak" />
                                    <TextBox Margin="0,4,0,0"
                                             IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                             Text="{Binding ConvertAudioTruePeakText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="LRA" />
                                    <TextBox Margin="0,4,0,0"
                                             IsEnabled="{Binding ConvertAudioIsEncodingEnabled}"
                                             Text="{Binding ConvertAudioLoudnessRangeText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Container" />
                                    <ComboBox Margin="0,4,0,0"
                                              ItemsSource="{Binding ConvertContainerOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding ConvertContainer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="Current preset" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource SecondaryTextBlockStyle}"
                                               TextWrapping="Wrap"
                                               Text="{Binding ConvertPresetName, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,12,0,0">
                                <CheckBox Margin="0,0,12,0"
                                          IsChecked="{Binding ConvertOverwriteExisting}"
                                          Content="Overwrite existing" />
                                <CheckBox Margin="0,0,12,0"
                                          IsEnabled="{Binding ConvertFastStartSupported}"
                                          IsChecked="{Binding ConvertFastStart}"
                                          Content="Fast start" />
                                <CheckBox IsChecked="{Binding ConvertUseHardwareAcceleration}"
                                          IsEnabled="{Binding ConvertHardwareAccelerationAvailable}"
                                          Content="Use hwaccel auto" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Style="{StaticResource SectionHeaderTextBlockStyle}"
                                   Text="Preview and execution" />
                        <WrapPanel DockPanel.Dock="Right">
                            <Button Margin="0,0,8,0"
                                    Command="{Binding CopyConvertCommandPreviewCommand}"
                                    Content="Copy Command" />
                            <Button Margin="0,0,8,0"
                                    Command="{Binding CreateConvertDraftCommand}"
                                    Content="Create Draft" />
                            <Button Margin="0,0,8,0"
                                    Command="{Binding AddConvertToQueueCommand}"
                                    Content="Add to Queue" />
                            <Button Margin="0,0,8,0"
                                    Command="{Binding RefreshConvertQueueOverviewCommand}"
                                    Content="Refresh Queue" />
                            <Button Margin="0,0,8,0"
                                    Command="{Binding ResetConvertOptionsCommand}"
                                    Content="Reset" />
                            <Button Command="{Binding RunConvertCommand}"
                                    Content="Run Convert" />
                        </WrapPanel>
                    </DockPanel>

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Validation" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource StatusInfoTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertValidationSummary}" />

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Advisories" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertAdvisorySummary}" />

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Generated FFmpeg command" />
                    <TextBox Margin="0,4,0,0"
                             MinHeight="120"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding ConvertCommandPreview, Mode=OneWay}" />

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Queue" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertQueueSummary, Mode=OneWay}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertQueueSnapshotSummary, Mode=OneWay}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertLastQueueJobSummary, Mode=OneWay}" />

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource LabelTextBlockStyle}"
                               Text="Recent Convert queue history" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertQueueHistoryStatus, Mode=OneWay}" />

                    <Border Margin="0,8,0,0"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding ConvertHasRecentQueueItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding ConvertRecentQueueItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,0,0,8"
                                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelTextBlockStyle}"
                                                       Text="{Binding Title}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource SecondaryTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Summary}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource SecondaryTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Detail}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource StatusInfoTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ConvertStatus}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
