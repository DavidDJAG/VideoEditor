<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark palette -->
    <Color x:Key="Color.Surface.Background">#111827</Color>
    <Color x:Key="Color.Surface.Panel">#1F2937</Color>
    <Color x:Key="Color.Surface.PanelAlt">#243041</Color>
    <Color x:Key="Color.Surface.Border">#334155</Color>

    <Color x:Key="Color.Text.Primary">#F9FAFB</Color>
    <Color x:Key="Color.Text.Secondary">#CBD5E1</Color>
    <Color x:Key="Color.Text.Disabled">#94A3B8</Color>

    <Color x:Key="Color.Brand.Primary">#3B82F6</Color>
    <Color x:Key="Color.Brand.PrimaryHover">#60A5FA</Color>
    <Color x:Key="Color.Brand.PrimaryPressed">#2563EB</Color>

    <!-- Contrast-safe semantic status colors -->
    <Color x:Key="Color.Status.Success">#22C55E</Color>
    <Color x:Key="Color.Status.Warning">#F59E0B</Color>
    <Color x:Key="Color.Status.Error">#EF4444</Color>
    <Color x:Key="Color.Status.Info">#38BDF8</Color>

    <SolidColorBrush x:Key="Brush.Surface.Background" Color="{StaticResource Color.Surface.Background}" />
    <SolidColorBrush x:Key="Brush.Surface.Panel" Color="{StaticResource Color.Surface.Panel}" />
    <SolidColorBrush x:Key="Brush.Surface.PanelAlt" Color="{StaticResource Color.Surface.PanelAlt}" />
    <SolidColorBrush x:Key="Brush.Surface.Border" Color="{StaticResource Color.Surface.Border}" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="{StaticResource Color.Text.Disabled}" />

    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{StaticResource Color.Brand.Primary}" />
    <SolidColorBrush x:Key="Brush.Brand.PrimaryHover" Color="{StaticResource Color.Brand.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.Brand.PrimaryPressed" Color="{StaticResource Color.Brand.PrimaryPressed}" />

    <SolidColorBrush x:Key="Brush.Status.Success" Color="{StaticResource Color.Status.Success}" />
    <SolidColorBrush x:Key="Brush.Status.Warning" Color="{StaticResource Color.Status.Warning}" />
    <SolidColorBrush x:Key="Brush.Status.Error" Color="{StaticResource Color.Status.Error}" />
    <SolidColorBrush x:Key="Brush.Status.Info" Color="{StaticResource Color.Status.Info}" />
</ResourceDictionary>
