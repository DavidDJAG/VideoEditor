<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Background}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Border}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.PanelAlt}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.PanelAlt}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Brand.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Brand.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Brand.PrimaryHover}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Brand.PrimaryHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Brand.PrimaryPressed}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Brand.PrimaryPressed}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource Brush.Surface.PanelAlt}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Border}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Disabled}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Reusable styles for queue grids, progress panels, log panes, dialogs -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Border}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="10" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface.PanelAlt}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Status.Info}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Border}" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Medium}" />
        <Setter Property="Padding" Value="{StaticResource Thickness.PanelPadding}" />
    </Style>

    <Style x:Key="DialogPanelStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.PanelAlt}" />
    </Style>

    <Style x:Key="StatusErrorTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Status.Error}" />
    </Style>

    <Style x:Key="StatusInfoTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextBlockStyle}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Status.Info}" />
    </Style>
</ResourceDictionary>
