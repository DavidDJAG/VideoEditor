<UserControl x:Class="VideoEditor.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:VideoEditor.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DashboardDesignViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="{StaticResource Text.Dashboard.Project}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           Text="{Binding CurrentProjectName}" />
                <TextBlock Margin="0,12,0,0"
                           Style="{StaticResource LabelTextBlockStyle}"
                           Text="{StaticResource Text.Dashboard.TimelineLength}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           Text="{Binding TimelineDurationLabel}" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="{StaticResource Text.Dashboard.ReadyTasks}" />
                <ItemsControl Margin="0,6,0,0"
                              ItemsSource="{Binding ReadyTasks}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource DialogPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource LabelTextBlockStyle}" Text="{StaticResource Text.Dashboard.StartupDiagnostics}" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource StatusErrorTextBlockStyle}"
                           TextWrapping="Wrap"
                           Text="{Binding BlockingError, Mode=OneWay}" />

                <TextBlock Margin="0,8,0,0">
                    <Run FontWeight="SemiBold" Text="{StaticResource Text.Dashboard.FfmpegPath}" />
                    <Run Text="{Binding FfmpegPath, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <Run FontWeight="SemiBold" Text="{StaticResource Text.Dashboard.FfprobePath}" />
                    <Run Text="{Binding FfprobePath, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <Run FontWeight="SemiBold" Text="{StaticResource Text.Dashboard.Version}" />
                    <Run Text="{Binding FfmpegVersion, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="{StaticResource Text.Dashboard.CodecSupport}" />
                    <Run Text="{Binding CodecSupportSummary, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="{StaticResource Text.Dashboard.HwAccel}" />
                    <Run Text="{Binding HardwareAccelerationSummary, Mode=OneWay}" />
                </TextBlock>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Style="{StaticResource LabelTextBlockStyle}"
                           Text="{StaticResource Text.Dashboard.ProbeJson}" />

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="120"
                             Text="{Binding DataContext.PreviewViewModel.ProbeSummary, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}" />

                    <TextBox Grid.Row="2"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding DataContext.PreviewViewModel.ProbeJson, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
