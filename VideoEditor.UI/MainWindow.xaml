<Window x:Class="VideoEditor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:VideoEditor.UI.ViewModels"
        xmlns:views="clr-namespace:VideoEditor.UI.Views"
        xmlns:moduleViews="clr-namespace:VideoEditor.UI.Views.Modules"
        mc:Ignorable="d"
        Title="{StaticResource Text.MainWindow.Title}"
        Background="{StaticResource Brush.Surface.Background}"
        Foreground="{StaticResource Brush.Text.Primary}"
        Width="1238"
        Height="735"
        d:DataContext="{d:DesignInstance Type=viewModels:MainWindowDesignViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="{StaticResource Thickness.WindowPadding}"
          Background="{StaticResource Brush.Surface.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{Binding Title}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource SecondaryTextBlockStyle}"
                       Text="{Binding Subtitle}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <TabControl>
                    <TabItem Header="Dashboard">
                        <ContentControl Content="{Binding DashboardViewModel}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                                    <views:DashboardView />
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </TabItem>

                    <TabItem Header="Cut/Trim">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Cut/Trim" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Input" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.TrimInputPath, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Output" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.TrimOutputPath, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock VerticalAlignment="Center" Text="Start" />
                                <TextBox Width="100" Margin="6,0,8,0" Text="{Binding ModulesWorkbenchViewModel.TrimStart, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock VerticalAlignment="Center" Text="End" />
                                <TextBox Width="100" Margin="6,0,0,0" Text="{Binding ModulesWorkbenchViewModel.TrimEnd, UpdateSourceTrigger=PropertyChanged}" />
                            </WrapPanel>
                            <Button Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ModulesWorkbenchViewModel.RunTrimCommand}"
                                    Content="Run Cut/Trim" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource StatusInfoTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ModulesWorkbenchViewModel.TrimStatus}" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Join/Concat">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Join/Concat" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Input A" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.ConcatInputA, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Input B" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.ConcatInputB, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Output" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.ConcatOutputPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ModulesWorkbenchViewModel.RunConcatCommand}"
                                    Content="Run Join/Concat" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource StatusInfoTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ModulesWorkbenchViewModel.ConcatStatus}" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Split A/V">
                        <moduleViews:SplitAvView DataContext="{Binding ModulesWorkbenchViewModel.SplitAvViewModel}" />
                    </TabItem>

                    <TabItem Header="Convert">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Convert" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Input" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.ConvertInputPath, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="Output" />
                            <TextBox Margin="0,4,0,0" Text="{Binding ModulesWorkbenchViewModel.ConvertOutputPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ModulesWorkbenchViewModel.RunConvertCommand}"
                                    Content="Run Convert" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource StatusInfoTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ModulesWorkbenchViewModel.ConvertStatus}" />
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="{StaticResource Text.Settings.Header}" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource LabelTextBlockStyle}" Text="{StaticResource Text.Settings.ToolsDirectory}" />
                    <TextBox Margin="0,4,0,0" Text="{Binding SettingsViewModel.ToolsDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding SettingsViewModel.RescanToolsCommand}"
                            Content="{StaticResource Text.Settings.RescanTools}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding SettingsViewModel.ScanStatus}" />

                    <Separator Margin="0,16,0,12" />
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="{StaticResource Text.Preview.Header}" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding PreviewViewModel.InputPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                MinWidth="92"
                                Command="{Binding PreviewViewModel.BrowseInputCommand}"
                                Content="{StaticResource Text.Preview.Browse}" />
                    </Grid>
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="{StaticResource Text.Preview.In}" />
                        <TextBox Width="90" Margin="6,0,8,0" Text="{Binding PreviewViewModel.InMarker, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="{StaticResource Text.Preview.Out}" />
                        <TextBox Width="90" Margin="6,0,0,0" Text="{Binding PreviewViewModel.OutMarker, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="{StaticResource Text.Preview.SubOffset}" />
                        <TextBox Width="90" Margin="6,0,8,0" Text="{Binding PreviewViewModel.SubtitleOffset, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="{StaticResource Text.Preview.Speed}" />
                        <TextBox Width="60" Margin="6,0,0,0" Text="{Binding PreviewViewModel.SpeedFactor, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>

                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="{StaticResource Text.Preview.MarkerA}" />
                        <TextBox Width="70" Margin="6,0,4,0" Text="{Binding PreviewViewModel.AStart, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="70" Margin="0,0,8,0" Text="{Binding PreviewViewModel.AEnd, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="{StaticResource Text.Preview.MarkerB}" />
                        <TextBox Width="70" Margin="6,0,4,0" Text="{Binding PreviewViewModel.BStart, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="70" Margin="0,0,0,0" Text="{Binding PreviewViewModel.BEnd, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>

                    <ComboBox Margin="0,8,0,0"
                              ItemsSource="{Binding PreviewViewModel.ProbeSeekPoints}"
                              SelectedItem="{Binding PreviewViewModel.SelectedSeek, Mode=TwoWay}" />
                    <WrapPanel Margin="0,8,0,0">
                        <Button MinWidth="72" Margin="0,0,6,0" Command="{Binding PreviewViewModel.LoadProbeCommand}" Content="{StaticResource Text.Preview.Probe}" />
                        <Button MinWidth="90" Margin="0,0,6,0" Command="{Binding PreviewViewModel.PlaySelectionCommand}" Content="{StaticResource Text.Preview.PlayIO}" />
                        <Button MinWidth="90" Margin="0,0,6,0" Command="{Binding PreviewViewModel.PlayAbCommand}" Content="{StaticResource Text.Preview.PlayAB}" />
                        <Button MinWidth="100" Margin="0,0,6,0" Command="{Binding PreviewViewModel.QuickSeekCommand}" Content="{StaticResource Text.Preview.QuickSeek}" />
                        <Button MinWidth="64" Command="{Binding PreviewViewModel.StopCommand}" Content="{StaticResource Text.Preview.Stop}" />
                    </WrapPanel>
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource StatusInfoTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding PreviewViewModel.Status}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
