<Window x:Class="VideoEditor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:VideoEditor.UI.ViewModels"
        xmlns:views="clr-namespace:VideoEditor.UI.Views"
        mc:Ignorable="d"
        Title="Video Editor"
        Width="980"
        Height="620"
        d:DataContext="{d:DesignInstance Type=viewModels:MainWindowDesignViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="DimGray"
                       Text="{Binding Subtitle}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="16"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6">
                <ContentControl Content="{Binding DashboardViewModel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                            <views:DashboardView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Settings" />
                    <TextBlock Margin="0,8,0,0" Text="Tools directory" FontWeight="SemiBold" />
                    <TextBox Margin="0,4,0,0" Text="{Binding SettingsViewModel.ToolsDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,12,0,0"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Command="{Binding SettingsViewModel.RescanToolsCommand}"
                            Content="Re-scan tools" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="DimGray"
                               TextWrapping="Wrap"
                               Text="{Binding SettingsViewModel.ScanStatus}" />

                    <Separator Margin="0,16,0,12" />
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Preview (ffplay)" />
                    <TextBox Margin="0,8,0,0" Text="{Binding PreviewViewModel.InputPath, UpdateSourceTrigger=PropertyChanged}" />
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="In" />
                        <TextBox Width="90" Margin="6,0,8,0" Text="{Binding PreviewViewModel.InMarker, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="Out" />
                        <TextBox Width="90" Margin="6,0,0,0" Text="{Binding PreviewViewModel.OutMarker, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="Sub offset" />
                        <TextBox Width="90" Margin="6,0,8,0" Text="{Binding PreviewViewModel.SubtitleOffset, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="Speed" />
                        <TextBox Width="60" Margin="6,0,0,0" Text="{Binding PreviewViewModel.SpeedFactor, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>

                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock VerticalAlignment="Center" Text="A" />
                        <TextBox Width="70" Margin="6,0,4,0" Text="{Binding PreviewViewModel.AStart, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="70" Margin="0,0,8,0" Text="{Binding PreviewViewModel.AEnd, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="B" />
                        <TextBox Width="70" Margin="6,0,4,0" Text="{Binding PreviewViewModel.BStart, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="70" Margin="0,0,0,0" Text="{Binding PreviewViewModel.BEnd, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>

                    <ComboBox Margin="0,8,0,0"
                              ItemsSource="{Binding PreviewViewModel.ProbeSeekPoints}"
                              SelectedItem="{Binding PreviewViewModel.SelectedSeek, Mode=TwoWay}" />
                    <WrapPanel Margin="0,8,0,0">
                        <Button Padding="8,4" Margin="0,0,6,0" Command="{Binding PreviewViewModel.LoadProbeCommand}" Content="Probe" />
                        <Button Padding="8,4" Margin="0,0,6,0" Command="{Binding PreviewViewModel.PlaySelectionCommand}" Content="Play I/O" />
                        <Button Padding="8,4" Margin="0,0,6,0" Command="{Binding PreviewViewModel.PlayAbCommand}" Content="Play A/B" />
                        <Button Padding="8,4" Margin="0,0,6,0" Command="{Binding PreviewViewModel.QuickSeekCommand}" Content="Quick seek" />
                        <Button Padding="8,4" Command="{Binding PreviewViewModel.StopCommand}" Content="Stop" />
                    </WrapPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="DimGray"
                               TextWrapping="Wrap"
                               Text="{Binding PreviewViewModel.Status}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
